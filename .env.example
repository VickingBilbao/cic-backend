# ============================================================
# CIC Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Redis (BullMQ) ---
# Local dev: redis://localhost:6379
# Railway:   provided automatically as REDIS_URL
REDIS_URL=redis://localhost:6379

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (Nano Banana 2 — image generation) ---
GOOGLE_API_KEY=AIza...

# --- HeyGen (Avatar video generation) ---
HEYGEN_API_KEY=your-heygen-api-key

# --- Cloudflare R2 (Image + Video storage) ---
# Account ID: Cloudflare Dashboard → right sidebar
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# R2 API tokens: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=cic-media
# Optional: public CDN URL if your bucket has a custom domain
# Leave empty to use pre-signed URLs instead
R2_PUBLIC_URL=https://media.your-domain.com

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Apify (web scraping for monitoring) ---
APIFY_TOKEN=your-apify-token

# --- OpenAI (embeddings for RAG only) ---
OPENAI_API_KEY=sk-...
